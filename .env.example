# ----------------------------------------------------------------------------
# Krydo — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored; this template is safe to commit.
# Server validates these at startup via server/config.ts (Zod schema).
# ----------------------------------------------------------------------------

# --- Firebase Admin SDK ---
# Two ways to supply the service-account credential — pick ONE:
#
#   Option A (local dev): point at a JSON file on disk. .gitignored.
GOOGLE_APPLICATION_CREDENTIALS=./your-service-account.json
#
#   Option B (production / Render / any ephemeral filesystem): paste the
#   entire service-account JSON as a single-line string. Preferred for
#   cloud deploys because it doesn't require a writable mount.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...",...}

FIREBASE_PROJECT_ID=your-firebase-project-id

# --- Ethereum / Sepolia ---
# Alchemy API key for the Sepolia network (not the full URL — just the key).
# Get one free at https://dashboard.alchemy.com -> Create App -> Ethereum -> Sepolia.
ALCHEMY_API_KEY=your-alchemy-api-key

# Deployer wallet private key (hex, NO 0x prefix). This wallet will:
#   - deploy KrydoAuthority + KrydoCredentials contracts
#   - be the on-chain root authority
#   - sign all server-side on-chain transactions
# Fund it with Sepolia ETH from a faucet: https://sepoliafaucet.com
# NEVER put a mainnet-funded key here.
DEPLOYER_PRIVATE_KEY=your-hex-private-key-without-0x-prefix

# --- Express / Auth ---
# Both must be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace-with-random-48-bytes-of-hex
JWT_SECRET=replace-with-different-random-48-bytes-of-hex
PORT=5000

# --- Security ---
# Comma-separated CORS allow-list. Leave empty in dev to allow any origin.
# In production set to your real domain(s), e.g.:
#   CORS_ORIGINS=https://krydo.app,https://app.krydo.app
CORS_ORIGINS=

# Per-IP rate-limiter window (ms) and max requests per window.
# Defaults shown. Lower these if you're seeing abuse.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Optional ---
# NODE_ENV defaults to "development" when running `npm run dev`.
# NODE_ENV=production

# --- Client (Vite build-time) ---
# WalletConnect project ID from https://cloud.walletconnect.com/
# Without this, WalletConnect is silently disabled and users only see
# MetaMask / Coinbase Wallet / injected (Rabby, Brave, Frame). Safe to
# leave unset while developing locally.
# VITE_WALLETCONNECT_PROJECT_ID=
